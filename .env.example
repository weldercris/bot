# Token do bot do Telegram (obtido no BotFather)
TELEGRAM_TOKEN=

# ID do chat/grupo que recebe as notificações
CHAT_ID=

# Opcional: ID do tópico (thread) em grupos com Tópicos ativados.
# Deixe vazio para enviar no tópico "General".
# Descubra com "npm run chat-id" após mandar uma mensagem no tópico desejado.
MESSAGE_THREAD_ID=

# Porta do servidor (o Render define automaticamente; local usa 3000)
PORT=3000

# Opcional: segredo para validar a origem do webhook.
# Se definido, o Jira deve enviar o header "x-webhook-secret" com este valor.
JIRA_WEBHOOK_SECRET=
